# Plot Agent 环境变量模板
# 用法：
#   1) 复制为 .env：cp .env.example .env
#   2) 填入你自己的 API Key
#   3) 启动时 src/utils.py 会自动加载（基于 python-dotenv）
#
# 这些变量优先级高于 config/config.yaml 中的同名字段，
# 因此 yaml 里的 api_key 可以留空。

# ---- LLM (OpenAI 兼容接口) ----
# 支持官方 OpenAI / 阿里 DashScope / 火山方舟 / 任意中转
OPENAI_API_KEY=sk-your-llm-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- Grsai 绘画 (Nano Banana / GPT Image) ----
# 申请地址：https://grsai.ai/zh/dashboard/api-keys
GRSAI_API_KEY=sk-your-grsai-api-key
GRSAI_BASE_URL=https://grsai.dakka.com.cn
